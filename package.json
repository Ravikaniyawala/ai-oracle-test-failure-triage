{
  "name": "ai-oracle",
  "version": "1.0.0",
  "description": "AI-powered Playwright test failure triage for GitLab CI",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js",
    "triage": "tsx src/index.ts",
    "triage:dry": "DRY_RUN=true tsx src/index.ts",
    "learn": "tsx src/learn.ts",
    "test": "tsx --test tests/**/*.test.ts",
    "test:live": "tsx --test tests/triage.test.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "better-sqlite3": "^12.8.0",
    "fast-xml-parser": "^4.3.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  }
}
