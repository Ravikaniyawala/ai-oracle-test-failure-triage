{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TriageApiResponse",
  "type": "object",
  "required": ["results"],
  "properties": {
    "results": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["testName", "category", "confidence", "reasoning", "suggested_fix", "create_jira"],
        "properties": {
          "testName": { "type": "string" },
          "category": {
            "type": "string",
            "enum": ["FLAKY", "REGRESSION", "ENV_ISSUE", "NEW_BUG"]
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "reasoning": { "type": "string" },
          "suggested_fix": { "type": "string" },
          "create_jira": { "type": "boolean" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
